#!/usr/bin/env bash
#
# syncz - Simple directory-to-directory syncer
#
# Uses unison for bidirectional sync (state-tracked) and rsync for
# unidirectional sync. Falls back to rsync for bidi when unison is
# not available.
#

set -euo pipefail

# Source common functions if not already loaded (from dispatcher)
if [[ "$(type -t info 2>/dev/null)" != "function" ]]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    UTILZ_HOME="${UTILZ_HOME:-$(cd "$SCRIPT_DIR/../.." && pwd)}"

    if [[ -f "$UTILZ_HOME/opt/utilz/lib/common.sh" ]]; then
        source "$UTILZ_HOME/opt/utilz/lib/common.sh"
    else
        echo "ERROR: Cannot find common.sh library" >&2
        exit 1
    fi
fi

# ============================================================================
# CONFIGURATION
# ============================================================================

OPT_DRY_RUN=false
OPT_FORCE=false
OPT_CONFIRM=false
OPT_SOURCE_WINS=false
OPT_DEST_WINS=false
OPT_DELETE=false
OPT_BACKUP=false
OPT_VERBOSE=false
OPT_PROGRESS=false
OPT_JUST_DO_IT=false
OPT_BIDI=false
EXCLUDE_PATTERNS=()
SOURCE_DIR=""
DEST_DIR=""

# Backend selection
OPT_BACKEND=""       # User-forced backend: "", "unison", "rsync"
OPT_FRESH=false      # --fresh: ignore unison archives
OPT_PREFER=""        # --prefer d1|d2|newer: force conflict resolution
OPT_NO_METADATA=false  # --no-metadata: ignore xattrs and resource forks
SYNCZ_BACKEND=""     # Resolved backend (set by select_backend)

# State for Y/N/A prompt
CONFIRM_ALL=false
CONFIRM_ANSWER=""

# ============================================================================
# USAGE
# ============================================================================

usage() {
    cat <<EOF
Usage: syncz [OPTIONS] <source-dir> <dest-dir>

Simple directory-to-directory syncer.

CONFLICT RESOLUTION:
  --source-wins            Source always overwrites dest
  --dest-wins              Dest files are never overwritten
  (default)                Only overwrite if source is newer

SAFETY:
  -n, --dry-run            Show what would happen without doing it
  -c, --confirm [yes|no|all]
                           Prompt before destructive actions (Y/N/A)
                           Optional arg auto-answers all prompts
  -f, --force              Force sync (no safety checks)
  --just-do-it             Show summary, single Y/N confirm, then run all

BIDIRECTIONAL:
  --bidi                   Two-way sync (uses unison when available)
  --backend unison|rsync   Force a specific sync backend
  --fresh                  Ignore saved state, treat as first sync
  --prefer d1|d2|newer     Force conflict resolution (unison only)
  --no-metadata            Ignore xattrs and resource forks (for cloud fs)

  When unison is available, --bidi uses it automatically (state-tracked sync).
  Falls back to rsync otherwise.

OPTIONS:
  -x, --exclude PAT        Exclude files matching pattern (repeatable)
  --ignore FILE            Read exclude patterns from file (one per line)
  --delete                 Remove dest files not in source
  -b, --backup             Create .syncz-bak copies of overwritten files
  -v, --verbose            Show detailed per-file output
  -p, --progress           Show per-file transfer progress
  -h, --help               Show this help
  --version                Show version

EXAMPLES:
  # Preview what would be synced
  syncz --dry-run ~/Documents/project /backup/project

  # Sync with confirmation prompts
  syncz --confirm ~/src /dst

  # Force sync, delete extra files, create backups
  syncz --force --delete --backup ~/src /dst

  # Quick confirm-and-go
  syncz --just-do-it --delete ~/src /dst

  # Bidirectional sync (uses unison if available)
  syncz --bidi ~/dir1 ~/dir2

  # Preview bidi sync without making changes
  syncz --bidi --dry-run ~/dir1 ~/dir2

For detailed help, run: utilz help syncz
EOF
}

# ============================================================================
# FUNCTIONS
# ============================================================================

# Resolve a path to an absolute path
resolve_path() {
    local dir="$1"
    if [[ -d "$dir" ]]; then
        (cd "$dir" && pwd)
    else
        echo "$dir"
    fi
}

# Validate inputs before syncing
validate_inputs() {
    # Check source and dest are provided
    if [[ -z "$SOURCE_DIR" || -z "$DEST_DIR" ]]; then
        error "Both source and destination directories are required"
        echo ""
        usage
        exit 1
    fi

    # Check source exists and is a directory
    if [[ ! -e "$SOURCE_DIR" ]]; then
        error "Source does not exist: $SOURCE_DIR"
        exit 1
    fi
    if [[ ! -d "$SOURCE_DIR" ]]; then
        error "Source is not a directory: $SOURCE_DIR"
        exit 1
    fi

    # Check dest exists and is a directory
    if [[ ! -e "$DEST_DIR" ]]; then
        error "Destination does not exist: $DEST_DIR"
        exit 1
    fi
    if [[ ! -d "$DEST_DIR" ]]; then
        error "Destination is not a directory: $DEST_DIR"
        exit 1
    fi

    # Resolve to absolute paths
    SOURCE_DIR="$(resolve_path "$SOURCE_DIR")"
    DEST_DIR="$(resolve_path "$DEST_DIR")"

    # Check source and dest are not the same
    if [[ "$SOURCE_DIR" == "$DEST_DIR" ]]; then
        error "Source and destination are the same directory: $SOURCE_DIR"
        exit 1
    fi

    # Bidi mode validations
    if [[ "$OPT_BIDI" == "true" ]]; then
        if [[ "$OPT_SOURCE_WINS" == "true" || "$OPT_DEST_WINS" == "true" ]]; then
            error "--source-wins and --dest-wins cannot be used with --bidi"
            info "Bidirectional mode uses newer-wins only"
            exit 1
        fi
        # In bidi mode, --delete is allowed without --confirm/--force/--just-do-it
        return 0
    fi

    # Check mutual exclusivity of conflict resolution flags
    if [[ "$OPT_SOURCE_WINS" == "true" && "$OPT_DEST_WINS" == "true" ]]; then
        error "--source-wins and --dest-wins are mutually exclusive"
        exit 1
    fi

    # Check mutual exclusivity of confirmation flags
    local confirm_count=0
    [[ "$OPT_FORCE" == "true" ]] && confirm_count=$((confirm_count + 1))
    [[ "$OPT_CONFIRM" == "true" ]] && confirm_count=$((confirm_count + 1))
    [[ "$OPT_JUST_DO_IT" == "true" ]] && confirm_count=$((confirm_count + 1))
    if [[ $confirm_count -gt 1 ]]; then
        error "--force, --confirm, and --just-do-it are mutually exclusive"
        exit 1
    fi

    # --delete requires --confirm, --force, or --just-do-it
    if [[ "$OPT_DELETE" == "true" ]]; then
        if [[ "$OPT_CONFIRM" != "true" && "$OPT_FORCE" != "true" && "$OPT_JUST_DO_IT" != "true" ]]; then
            error "--delete requires --confirm, --force, or --just-do-it"
            info "This prevents accidental deletion of files"
            exit 1
        fi
    fi
}

# Build rsync argument array from options
# Sets global _RSYNC_ARGS array (avoids bash 4.3+ namerefs for portability)
build_rsync_args() {
    local include_delete=${1:-true}
    _RSYNC_ARGS=()

    # Base flags: recursive, links, permissions, timestamps, devices
    _RSYNC_ARGS+=("-rlptD")

    # Conflict resolution
    if [[ "$OPT_SOURCE_WINS" == "true" ]]; then
        : # No --update flag, source always overwrites
    elif [[ "$OPT_DEST_WINS" == "true" ]]; then
        _RSYNC_ARGS+=("--ignore-existing")
    else
        # Default: newer-wins
        _RSYNC_ARGS+=("--update")
    fi

    # Verbose mode
    if [[ "$OPT_VERBOSE" == "true" ]]; then
        _RSYNC_ARGS+=("--itemize-changes")
    fi

    # Progress mode
    if [[ "$OPT_PROGRESS" == "true" ]]; then
        _RSYNC_ARGS+=("--progress")
    fi

    # Delete mode
    if [[ "$OPT_DELETE" == "true" && "$include_delete" == "true" ]]; then
        _RSYNC_ARGS+=("--delete")
    fi

    # Backup mode
    if [[ "$OPT_BACKUP" == "true" ]]; then
        _RSYNC_ARGS+=("--backup" "--suffix=.syncz-bak")
    fi

    # Exclude patterns (guard for bash 3.2 where empty array is unbound with set -u)
    if [[ ${#EXCLUDE_PATTERNS[@]} -gt 0 ]]; then
        for pattern in "${EXCLUDE_PATTERNS[@]}"; do
            _RSYNC_ARGS+=("--exclude=$pattern")
        done
    fi
}

# Generate a summary by running rsync in dry-run mode
generate_summary() {
    build_rsync_args true
    local rsync_args=("${_RSYNC_ARGS[@]}")

    # Add dry-run and stats
    rsync_args+=("--dry-run" "--stats")

    # Add source and dest with trailing slashes
    rsync_args+=("${SOURCE_DIR}/" "${DEST_DIR}/")

    # Run rsync and capture output
    local rsync_output
    rsync_output=$(rsync "${rsync_args[@]}" 2>&1) || true

    # Parse stats
    local files_transferred=0
    local total_size=0
    local files_deleted=0

    # Handle both old rsync ("Number of files transferred:") and new ("Number of regular files transferred:")
    files_transferred=$(echo "$rsync_output" | grep -E "^Number of (regular )?files transferred:" | head -1 | sed 's/[^0-9]//g' || echo "0")
    [[ -z "$files_transferred" ]] && files_transferred=0

    if [[ "$OPT_DELETE" == "true" ]]; then
        files_deleted=$(echo "$rsync_output" | grep -E "^Number of deleted files:" | head -1 | sed 's/[^0-9,]//g' | tr -d ',' || echo "0")
        [[ -z "$files_deleted" ]] && files_deleted=0
    fi

    # Determine conflict mode label
    local mode="newer-wins (default)"
    if [[ "$OPT_SOURCE_WINS" == "true" ]]; then
        mode="source-wins"
    elif [[ "$OPT_DEST_WINS" == "true" ]]; then
        mode="dest-wins"
    fi

    # Display summary
    echo ""
    echo "Sync Summary"
    echo "============"
    echo "  Source:    ${SOURCE_DIR}/"
    echo "  Dest:     ${DEST_DIR}/"
    echo "  Mode:     $mode"
    echo "  Files:    $files_transferred to transfer"
    if [[ "$OPT_DELETE" == "true" ]]; then
        echo "  Delete:   $files_deleted to remove from dest"
    fi
    if [[ "$OPT_BACKUP" == "true" ]]; then
        echo "  Backup:   .syncz-bak copies of overwritten files"
    fi
    echo ""

    # Return counts via globals
    SUMMARY_FILES_TRANSFERRED=$files_transferred
    SUMMARY_FILES_DELETED=$files_deleted

    # If verbose or dry-run, show the itemized output
    if [[ "$OPT_VERBOSE" == "true" || "$OPT_DRY_RUN" == "true" ]]; then
        # Re-run with itemize for detailed listing
        build_rsync_args true
        local detail_args=("${_RSYNC_ARGS[@]}")
        detail_args+=("--dry-run" "--itemize-changes")
        detail_args+=("${SOURCE_DIR}/" "${DEST_DIR}/")
        local detail_output
        detail_output=$(rsync "${detail_args[@]}" 2>&1 | grep -v "^$" | head -50) || true
        if [[ -n "$detail_output" ]]; then
            echo "Changes:"
            echo "$detail_output"
            echo ""
        fi
    fi
}

# Prompt Y/N/A - returns 0 for yes/all, 1 for no
# Sets CONFIRM_ALL=true if user answers A
prompt_yna() {
    local message="$1"

    # Auto-answer from --confirm arg
    if [[ -n "$CONFIRM_ANSWER" ]]; then
        case "$CONFIRM_ANSWER" in
            yes|all) CONFIRM_ALL=true; return 0 ;;
            no)      return 1 ;;
        esac
    fi

    # If already confirmed all, return yes
    if [[ "$CONFIRM_ALL" == "true" ]]; then
        return 0
    fi

    printf '%s [Y/N/A] ' "$message" >&2
    local answer
    # Read from /dev/tty for interactive use; fall back to stdin for piped input
    if [[ ! -t 0 ]]; then
        read -r answer
    else
        read -r answer </dev/tty
    fi

    # Lowercase for comparison (portable, avoids bash 4.0+ ${var,,})
    answer=$(echo "$answer" | tr '[:upper:]' '[:lower:]')
    case "$answer" in
        y|yes)
            return 0
            ;;
        a|all)
            CONFIRM_ALL=true
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

# Simple Y/N prompt - returns 0 for yes, 1 for no
prompt_yn() {
    local message="$1"

    # Auto-answer from --confirm arg
    if [[ -n "$CONFIRM_ANSWER" ]]; then
        case "$CONFIRM_ANSWER" in
            yes|all) return 0 ;;
            no)      return 1 ;;
        esac
    fi

    printf '%s [Y/N] ' "$message" >&2
    local answer
    # Read from /dev/tty for interactive use; fall back to stdin for piped input
    if [[ ! -t 0 ]]; then
        read -r answer
    else
        read -r answer </dev/tty
    fi

    # Lowercase for comparison (portable, avoids bash 4.0+ ${var,,})
    answer=$(echo "$answer" | tr '[:upper:]' '[:lower:]')
    case "$answer" in
        y|yes)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

# Execute a delete-only pass (used by --confirm mode)
execute_delete() {
    local delete_args=("-rlptD" "--delete")
    if [[ ${#EXCLUDE_PATTERNS[@]} -gt 0 ]]; then
        for pattern in "${EXCLUDE_PATTERNS[@]}"; do
            delete_args+=("--exclude=$pattern")
        done
    fi
    delete_args+=("${SOURCE_DIR}/" "${DEST_DIR}/")
    rsync "${delete_args[@]}" || true
    success "Delete complete"
}

# Execute the actual rsync sync
execute_sync() {
    local include_delete=${1:-true}
    build_rsync_args "$include_delete"
    local rsync_args=("${_RSYNC_ARGS[@]}")

    # Add source and dest with trailing slashes
    rsync_args+=("${SOURCE_DIR}/" "${DEST_DIR}/")

    # Run rsync
    local exit_code=0
    rsync "${rsync_args[@]}" || exit_code=$?

    if [[ $exit_code -eq 0 ]]; then
        success "Sync complete"
    elif [[ $exit_code -eq 23 ]]; then
        # Exit 23 = partial transfer due to permission errors (common for non-root syncs)
        warn "Sync complete with some permission warnings (rsync exit 23)"
    else
        error "rsync exited with code $exit_code"
        return $exit_code
    fi
}

# ============================================================================
# PATH DISPLAY
# ============================================================================

# Find the longest common directory suffix of two paths.
# Sets _PATH_SUFFIX (common tail) and _PATH_ROOT1, _PATH_ROOT2 (unique prefixes).
_compute_path_labels() {
    local p1="$1" p2="$2"

    # Split into arrays by /
    local IFS='/'
    local -a parts1=($p1) parts2=($p2)

    # Walk backwards from the end to find common suffix
    local i1=$(( ${#parts1[@]} - 1 ))
    local i2=$(( ${#parts2[@]} - 1 ))
    local -a suffix=()
    while [[ $i1 -ge 0 && $i2 -ge 0 ]]; do
        if [[ "${parts1[$i1]}" == "${parts2[$i2]}" ]]; then
            suffix=("${parts1[$i1]}" "${suffix[@]}")
            i1=$((i1 - 1))
            i2=$((i2 - 1))
        else
            break
        fi
    done

    # Build the suffix string
    _PATH_SUFFIX=""
    for part in "${suffix[@]}"; do
        if [[ -n "$_PATH_SUFFIX" ]]; then
            _PATH_SUFFIX="$_PATH_SUFFIX/$part"
        else
            _PATH_SUFFIX="$part"
        fi
    done

    # Build root strings (everything before the common suffix)
    if [[ -n "$_PATH_SUFFIX" ]]; then
        _PATH_ROOT1="${p1%/$_PATH_SUFFIX}"
        _PATH_ROOT2="${p2%/$_PATH_SUFFIX}"
    else
        _PATH_ROOT1="$p1"
        _PATH_ROOT2="$p2"
    fi
}

# ============================================================================
# BACKEND SELECTION
# ============================================================================

select_backend() {
    if [[ -n "$OPT_BACKEND" ]]; then
        SYNCZ_BACKEND="$OPT_BACKEND"
    elif [[ "$OPT_BIDI" == "true" ]] && command -v unison &>/dev/null; then
        SYNCZ_BACKEND=unison
    else
        SYNCZ_BACKEND=rsync
    fi

    # Validate backend is available
    if [[ "$SYNCZ_BACKEND" == "unison" ]] && ! command -v unison &>/dev/null; then
        error "unison not found. Install: brew install unison"
        exit 1
    fi
    if [[ "$SYNCZ_BACKEND" == "rsync" ]] && ! command -v rsync &>/dev/null; then
        error "rsync not found. Install: brew install rsync"
        exit 1
    fi

    # Warn about rsync fallback in bidi mode
    if [[ "$OPT_BIDI" == "true" && "$SYNCZ_BACKEND" == "rsync" && -z "$OPT_BACKEND" ]]; then
        warn "unison not found; falling back to rsync (no state tracking for bidi)"
    fi
}

# ============================================================================
# UNISON BIDI
# ============================================================================

# Build common unison args from syncz options
# Sets _UNISON_ARGS array
_unison_build_common_args() {
    local dir1="$1"
    local dir2="$2"
    _UNISON_ARGS=("$dir1" "$dir2" -times -ui text)

    # Ignore macOS metadata (xattrs, resource forks) — useful for cloud filesystems
    if [[ "$OPT_NO_METADATA" == "true" ]]; then
        _UNISON_ARGS+=(-xattrs=false -rsrc=false)
    fi

    # Prefer: force one side to win conflicts
    if [[ -n "${OPT_PREFER:-}" ]]; then
        if [[ "$OPT_PREFER" == "dir1" || "$OPT_PREFER" == "d1" ]]; then
            _UNISON_ARGS+=(-prefer "$dir1")
        elif [[ "$OPT_PREFER" == "dir2" || "$OPT_PREFER" == "d2" ]]; then
            _UNISON_ARGS+=(-prefer "$dir2")
        elif [[ "$OPT_PREFER" == "newer" ]]; then
            _UNISON_ARGS+=(-prefer newer)
        else
            _UNISON_ARGS+=(-prefer "$OPT_PREFER")
        fi
    fi

    # Fresh: ignore saved archives
    [[ "$OPT_FRESH" == "true" ]] && _UNISON_ARGS+=(-ignorearchives)

    # Exclude patterns
    if [[ ${#EXCLUDE_PATTERNS[@]} -gt 0 ]]; then
        for pat in "${EXCLUDE_PATTERNS[@]}"; do
            _UNISON_ARGS+=(-ignore "Name $pat")
        done
    fi

    # Backup
    [[ "$OPT_BACKUP" == "true" ]] && _UNISON_ARGS+=(-backup "Name *" -backupsuffix .syncz-bak)

    # Verbose: unison default is informative; suppress with -terse when not verbose
    if [[ "$OPT_VERBOSE" != "true" ]]; then
        _UNISON_ARGS+=(-terse)
    fi
}

# Dry-run for unison bidi: block all mutations, show what would happen
unison_bidi_dryrun() {
    local dir1="$SOURCE_DIR"
    local dir2="$DEST_DIR"

    _unison_build_common_args "$dir1" "$dir2"
    local -a args=("${_UNISON_ARGS[@]}")
    args+=(-batch -auto)

    # Block all changes on both sides
    args+=(-nocreation "$dir1" -nocreation "$dir2")
    args+=(-nodeletion "$dir1" -nodeletion "$dir2")
    args+=(-noupdate "$dir1" -noupdate "$dir2")

    # Compute display labels
    _compute_path_labels "$dir1" "$dir2"

    # Header (skip roots if caller already printed them)
    if [[ -z "${SYNCZ_ROOTS_SHOWN:-}" ]]; then
        echo ""
        echo "Bidirectional sync (unison) — DRY RUN"
        echo "======================================"
        echo "  D1:  $_PATH_ROOT1"
        echo "  D2:  $_PATH_ROOT2"
        if [[ -n "$_PATH_SUFFIX" ]]; then
            echo "  Dir: $_PATH_SUFFIX/"
        fi
        echo ""
    fi

    # Run unison with all mutations blocked; capture output
    local output
    output=$(unison "${args[@]}" 2>&1) || true

    # Parse and display the plan
    local line filename action_count=0

    # Parse skipped lines to get filenames, check filesystem for direction
    # Format: "  skipped: filename (would create/update ...)"
    while IFS= read -r line; do
        if [[ ! "$line" =~ skipped:\ (.+)\ \( ]]; then
            continue
        fi
        filename="${BASH_REMATCH[1]}"
        # Determine action type from the reason in parentheses
        local reason=""
        if [[ "$line" =~ \((.+)\)$ ]]; then
            reason="${BASH_REMATCH[1]}"
        fi
        # Skip directory entries (unison reports dirs separately)
        if [[ -d "$dir1/$filename" || -d "$dir2/$filename" ]] && \
           [[ ! -f "$dir1/$filename" && ! -f "$dir2/$filename" ]]; then
            continue
        fi
        if [[ "$reason" =~ "contents changed on both sides" ]]; then
            echo "  [CONFLICT]  $filename  (modified on both sides)"
        elif [[ -f "$dir1/$filename" && ! -f "$dir2/$filename" ]]; then
            echo "  [new]  D1 → D2  $filename"
        elif [[ -f "$dir2/$filename" && ! -f "$dir1/$filename" ]]; then
            echo "  [new]  D2 → D1  $filename"
        elif [[ -f "$dir1/$filename" && -f "$dir2/$filename" ]]; then
            echo "  [changed]  $filename"
        fi
        action_count=$((action_count + 1))
    done <<< "$output"

    # Summary
    echo ""
    if [[ $action_count -gt 0 ]]; then
        echo "  $action_count file(s) would be synced."
    else
        echo "  Already in sync."
    fi

    # Show verbose detail if requested
    if [[ "$OPT_VERBOSE" == "true" ]]; then
        local skipped_lines
        skipped_lines=$(echo "$output" | grep "skipped:" || true)
        if [[ -n "$skipped_lines" ]]; then
            echo ""
            echo "Details:"
            echo "$skipped_lines" | while IFS= read -r line; do
                echo "  $line"
            done
        fi
    fi

    echo ""
    info "Dry run - no changes made"
}

unison_bidi() {
    local dir1="$SOURCE_DIR"
    local dir2="$DEST_DIR"

    # Dry-run: use blocking approach
    if [[ "$OPT_DRY_RUN" == "true" ]]; then
        unison_bidi_dryrun
        return $?
    fi

    _unison_build_common_args "$dir1" "$dir2"
    local -a args=("${_UNISON_ARGS[@]}")

    # --delete deprecation in unison bidi
    if [[ "$OPT_DELETE" == "true" ]]; then
        warn "--delete is a no-op in unison bidi mode (deletions are state-tracked)"
    fi

    # Confirmation modes → -batch/-auto control
    if [[ "$OPT_CONFIRM" == "true" && -z "$CONFIRM_ANSWER" ]]; then
        : # Bare --confirm: no -batch, unison prompts per-file interactively
    elif [[ "$CONFIRM_ANSWER" == "no" ]]; then
        info "Aborted."
        return 0
    elif [[ "$OPT_JUST_DO_IT" == "true" ]]; then
        _compute_path_labels "$dir1" "$dir2"
        echo ""
        echo "Bidirectional sync (unison)"
        echo "==========================="
        echo "  D1:  $_PATH_ROOT1"
        echo "  D2:  $_PATH_ROOT2"
        if [[ -n "$_PATH_SUFFIX" ]]; then
            echo "  Dir: $_PATH_SUFFIX/"
        fi
        echo ""
        if ! prompt_yn "Proceed with bidirectional sync?"; then
            info "Aborted."
            return 0
        fi
        args+=(-batch -auto)
    else
        # Default, --force, --confirm yes/all: batch mode
        args+=(-batch -auto)
    fi

    # Compute display labels (if not already done by --just-do-it)
    if [[ -z "${_PATH_ROOT1:-}" ]]; then
        _compute_path_labels "$dir1" "$dir2"
    fi

    # Header (skip roots if caller already printed them)
    if [[ -z "${SYNCZ_ROOTS_SHOWN:-}" ]]; then
        echo ""
        echo "Bidirectional sync (unison)"
        echo "==========================="
        echo "  D1:  $_PATH_ROOT1"
        echo "  D2:  $_PATH_ROOT2"
        if [[ -n "$_PATH_SUFFIX" ]]; then
            echo "  Dir: $_PATH_SUFFIX/"
        fi
        echo ""
    fi

    # Execute
    local rc=0
    unison "${args[@]}" || rc=$?

    echo ""
    case $rc in
        0) echo "Sync complete." ;;
        1) echo "Sync complete (some items skipped — see above for conflicts)." ;;
        *) error "unison exited with code $rc"; return $rc ;;
    esac
}

# ============================================================================
# BIDI FUNCTIONS (rsync fallback)
# ============================================================================

# Detect files that exist on only one side (orphans)
# Populates ORPHANS_DIR1 and ORPHANS_DIR2 arrays
detect_orphans() {
    local dir1="$1"
    local dir2="$2"

    ORPHANS_DIR1=()
    ORPHANS_DIR2=()

    # Build exclude args for find
    local find_excludes=()
    if [[ ${#EXCLUDE_PATTERNS[@]} -gt 0 ]]; then
        for pattern in "${EXCLUDE_PATTERNS[@]}"; do
            find_excludes+=(-not -name "$pattern")
        done
    fi

    # Get sorted file lists relative to each dir
    local files1 files2
    if [[ ${#find_excludes[@]} -gt 0 ]]; then
        files1=$(cd "$dir1" && find . -type f "${find_excludes[@]}" 2>/dev/null | sort) || true
        files2=$(cd "$dir2" && find . -type f "${find_excludes[@]}" 2>/dev/null | sort) || true
    else
        files1=$(cd "$dir1" && find . -type f 2>/dev/null | sort) || true
        files2=$(cd "$dir2" && find . -type f 2>/dev/null | sort) || true
    fi

    # Files only in dir1 (orphans on dir1 side)
    local only_in_dir1
    only_in_dir1=$(comm -23 <(echo "$files1") <(echo "$files2")) || true

    # Files only in dir2 (orphans on dir2 side)
    local only_in_dir2
    only_in_dir2=$(comm -13 <(echo "$files1") <(echo "$files2")) || true

    # Populate arrays (strip leading ./)
    while IFS= read -r f; do
        if [[ -n "$f" ]]; then
            ORPHANS_DIR1+=("${f#./}")
        fi
    done <<< "$only_in_dir1"

    while IFS= read -r f; do
        if [[ -n "$f" ]]; then
            ORPHANS_DIR2+=("${f#./}")
        fi
    done <<< "$only_in_dir2"
}

# Resolve orphans by deleting, prompting, or skipping
resolve_orphans() {
    local dir1="$1"
    local dir2="$2"

    local total=$(( ${#ORPHANS_DIR1[@]} + ${#ORPHANS_DIR2[@]} ))
    if [[ $total -eq 0 ]]; then
        if [[ "$OPT_VERBOSE" == "true" ]]; then
            echo ""
            echo "No orphaned files detected."
            echo ""
        fi
        return 0
    fi

    # Labels: use last path component for readability
    local label1 label2
    label1=$(basename "$dir1")
    label2=$(basename "$dir2")

    echo ""
    echo "Orphans"
    echo "======="
    echo "  $total file(s) exist on one side only."
    echo ""

    # Dry-run: just list and return
    if [[ "$OPT_DRY_RUN" == "true" ]]; then
        if [[ ${#ORPHANS_DIR1[@]} -gt 0 ]]; then
            for f in "${ORPHANS_DIR1[@]}"; do
                echo "  [$label1] $f"
            done
        fi
        if [[ ${#ORPHANS_DIR2[@]} -gt 0 ]]; then
            for f in "${ORPHANS_DIR2[@]}"; do
                echo "  [$label2] $f"
            done
        fi
        echo ""
        return 0
    fi

    # --delete mode: delete all orphans with warning
    if [[ "$OPT_DELETE" == "true" ]]; then
        echo "  WARNING: Deleting $total orphan(s). This is IRREVERSIBLE."
        echo ""
        if [[ ${#ORPHANS_DIR1[@]} -gt 0 ]]; then
            for f in "${ORPHANS_DIR1[@]}"; do
                rm -f "$dir1/$f"
                if [[ "$OPT_VERBOSE" == "true" ]]; then echo "  Deleted [$label1] $f"; fi
            done
        fi
        if [[ ${#ORPHANS_DIR2[@]} -gt 0 ]]; then
            for f in "${ORPHANS_DIR2[@]}"; do
                rm -f "$dir2/$f"
                if [[ "$OPT_VERBOSE" == "true" ]]; then echo "  Deleted [$label2] $f"; fi
            done
        fi
        echo "  Deleted $total orphan(s)."
        echo ""
        return 0
    fi

    # Interactive or --confirm arg mode
    local delete_all=false

    # No explicit orphan handling → default: keep orphans (rsync will copy them)
    if [[ -z "$CONFIRM_ANSWER" && "$OPT_CONFIRM" != "true" ]]; then
        if [[ ${#ORPHANS_DIR1[@]} -gt 0 ]]; then
            for f in "${ORPHANS_DIR1[@]}"; do
                echo "  [$label1] $f"
            done
        fi
        if [[ ${#ORPHANS_DIR2[@]} -gt 0 ]]; then
            for f in "${ORPHANS_DIR2[@]}"; do
                echo "  [$label2] $f"
            done
        fi
        echo ""
        echo "  Keeping all orphans (will be synced to both sides)."
        echo "  Use --delete to remove, or --confirm to prompt per-file."
        echo ""
        return 0
    fi

    # --confirm arg mode (yes/no/all)
    if [[ -n "$CONFIRM_ANSWER" ]]; then
        if [[ ${#ORPHANS_DIR1[@]} -gt 0 ]]; then
            for f in "${ORPHANS_DIR1[@]}"; do
                echo "  [$label1] $f"
                case "$CONFIRM_ANSWER" in
                    yes|all) rm -f "$dir1/$f" ;;
                    no)      : ;; # keep — sync will copy it
                esac
            done
        fi
        if [[ ${#ORPHANS_DIR2[@]} -gt 0 ]]; then
            for f in "${ORPHANS_DIR2[@]}"; do
                echo "  [$label2] $f"
                case "$CONFIRM_ANSWER" in
                    yes|all) rm -f "$dir2/$f" ;;
                    no)      : ;;
                esac
            done
        fi
        echo ""
        return 0
    fi

    # --confirm (no arg) → interactive prompts with KEEP as default
    echo "  ┌─────────────────────────────────────────────────────────┐"
    echo "  │  WARNING: Deleting orphans is IRREVERSIBLE.            │"
    echo "  │  Files deleted here are permanently removed, not moved │"
    echo "  │  to trash. Press Enter or 'n' to keep (safe default).  │"
    echo "  └─────────────────────────────────────────────────────────┘"
    echo ""

    if [[ ${#ORPHANS_DIR1[@]} -gt 0 ]]; then
        for f in "${ORPHANS_DIR1[@]}"; do
            echo "  [$label1] $f"
            if [[ "$delete_all" == "true" ]]; then
                rm -f "$dir1/$f"
                if [[ "$OPT_VERBOSE" == "true" ]]; then echo "  Deleted."; fi
            else
                printf '  Delete? [y/N/a] ' >&2
                local answer
                if [[ ! -t 0 ]]; then
                    read -r answer
                else
                    read -r answer </dev/tty
                fi
                answer=$(echo "$answer" | tr '[:upper:]' '[:lower:]')
                case "$answer" in
                    y|yes)    rm -f "$dir1/$f" ;;
                    a|all)    delete_all=true; rm -f "$dir1/$f" ;;
                    *)        : ;; # default: keep
                esac
            fi
        done
    fi

    if [[ ${#ORPHANS_DIR2[@]} -gt 0 ]]; then
        for f in "${ORPHANS_DIR2[@]}"; do
            echo "  [$label2] $f"
            if [[ "$delete_all" == "true" ]]; then
                rm -f "$dir2/$f"
                if [[ "$OPT_VERBOSE" == "true" ]]; then echo "  Deleted."; fi
            else
                printf '  Delete? [y/N/a] ' >&2
                local answer
                if [[ ! -t 0 ]]; then
                    read -r answer
                else
                    read -r answer </dev/tty
                fi
                answer=$(echo "$answer" | tr '[:upper:]' '[:lower:]')
                case "$answer" in
                    y|yes)    rm -f "$dir2/$f" ;;
                    a|all)    delete_all=true; rm -f "$dir2/$f" ;;
                    *)        : ;; # default: keep
                esac
            fi
        done
    fi

    echo ""
}

# Execute bidirectional sync: detect orphans → resolve → two-pass sync
execute_bidi() {
    local dir1="$SOURCE_DIR"
    local dir2="$DEST_DIR"

    # Step 1: Detect and resolve orphans
    detect_orphans "$dir1" "$dir2"
    resolve_orphans "$dir1" "$dir2"

    # Step 2: Pass 1 — dir1 → dir2 (never pass --delete to rsync in bidi mode)
    local saved_delete="$OPT_DELETE"
    OPT_DELETE=false

    if [[ "$OPT_VERBOSE" == "true" || "$OPT_DRY_RUN" == "true" ]]; then
        echo "Pass 1: $(basename "$dir1") → $(basename "$dir2")"
        echo "---"
    fi

    SUMMARY_FILES_TRANSFERRED=0
    SUMMARY_FILES_DELETED=0
    generate_summary

    if [[ "$OPT_DRY_RUN" != "true" ]]; then
        execute_sync false
    fi

    # Step 3: Pass 2 — dir2 → dir1 (swap source/dest)
    local orig_source="$SOURCE_DIR"
    local orig_dest="$DEST_DIR"
    SOURCE_DIR="$dir2"
    DEST_DIR="$dir1"

    if [[ "$OPT_VERBOSE" == "true" || "$OPT_DRY_RUN" == "true" ]]; then
        echo ""
        echo "Pass 2: $(basename "$dir2") → $(basename "$dir1")"
        echo "---"
    fi

    SUMMARY_FILES_TRANSFERRED=0
    SUMMARY_FILES_DELETED=0
    generate_summary

    if [[ "$OPT_DRY_RUN" != "true" ]]; then
        execute_sync false
    fi

    # Restore state
    SOURCE_DIR="$orig_source"
    DEST_DIR="$orig_dest"
    OPT_DELETE="$saved_delete"

    if [[ "$OPT_DRY_RUN" == "true" ]]; then
        info "Dry run - no changes made"
    fi
}

# ============================================================================
# MAIN
# ============================================================================

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        --version)
            show_version "syncz"
            exit 0
            ;;
        -n|--dry-run)
            OPT_DRY_RUN=true
            shift
            ;;
        -f|--force)
            OPT_FORCE=true
            shift
            ;;
        -c|--confirm)
            OPT_CONFIRM=true
            # Peek at next arg for optional value
            if [[ "${2:-}" =~ ^(yes|no|all)$ ]]; then
                CONFIRM_ANSWER="$2"
                shift 2
            else
                shift
            fi
            ;;
        --bidi)
            OPT_BIDI=true
            shift
            ;;
        --source-wins)
            OPT_SOURCE_WINS=true
            shift
            ;;
        --dest-wins)
            OPT_DEST_WINS=true
            shift
            ;;
        -x|--exclude)
            if [[ -z "${2:-}" ]]; then
                error "Option --exclude requires a pattern"
                exit 1
            fi
            EXCLUDE_PATTERNS+=("$2")
            shift 2
            ;;
        --ignore)
            if [[ -z "${2:-}" ]]; then
                error "Option --ignore requires a file path"
                exit 1
            fi
            if [[ ! -f "$2" ]]; then
                error "Ignore file not found: $2"
                exit 1
            fi
            while IFS= read -r line || [[ -n "$line" ]]; do
                line="${line%%#*}"     # strip comments
                line="${line// /}"     # strip whitespace
                [[ -n "$line" ]] && EXCLUDE_PATTERNS+=("$line")
            done < "$2"
            shift 2
            ;;
        --delete)
            OPT_DELETE=true
            shift
            ;;
        -b|--backup)
            OPT_BACKUP=true
            shift
            ;;
        -v|--verbose)
            OPT_VERBOSE=true
            shift
            ;;
        -p|--progress)
            OPT_PROGRESS=true
            shift
            ;;
        --just-do-it)
            OPT_JUST_DO_IT=true
            shift
            ;;
        --backend)
            if [[ "${2:-}" =~ ^(unison|rsync)$ ]]; then
                OPT_BACKEND="$2"
                shift 2
            else
                error "--backend requires 'unison' or 'rsync'"
                exit 1
            fi
            ;;
        --fresh)
            OPT_FRESH=true
            shift
            ;;
        --prefer)
            if [[ -n "${2:-}" ]]; then
                OPT_PREFER="$2"
                shift 2
            else
                error "--prefer requires an argument: d1, d2, newer, or a path"
                exit 1
            fi
            ;;
        --no-metadata)
            OPT_NO_METADATA=true
            shift
            ;;
        -*)
            error "Unknown option: $1"
            echo ""
            usage
            exit 1
            ;;
        *)
            # Positional arguments: source and dest
            if [[ -z "$SOURCE_DIR" ]]; then
                SOURCE_DIR="$1"
            elif [[ -z "$DEST_DIR" ]]; then
                DEST_DIR="$1"
            else
                error "Too many arguments"
                echo ""
                usage
                exit 1
            fi
            shift
            ;;
    esac
done

# Validate inputs
validate_inputs

# Select sync backend
select_backend

# Backend-aware validations
if [[ "$OPT_FRESH" == "true" && "$SYNCZ_BACKEND" == "rsync" ]]; then
    warn "--fresh has no effect with rsync backend (rsync has no state)"
fi

# --- Bidi mode: delegate to backend ---
if [[ "$OPT_BIDI" == "true" ]]; then
    if [[ "$SYNCZ_BACKEND" == "unison" ]]; then
        unison_bidi
    else
        execute_bidi
    fi
    exit $?
fi

# Generate summary
SUMMARY_FILES_TRANSFERRED=0
SUMMARY_FILES_DELETED=0
generate_summary

# --- Dry-run mode: display summary and exit ---
if [[ "$OPT_DRY_RUN" == "true" ]]; then
    info "Dry run - no changes made"
    exit 0
fi

# --- Force mode: no prompts, just run ---
if [[ "$OPT_FORCE" == "true" ]]; then
    execute_sync true
    exit $?
fi

# --- Just-do-it mode: single Y/N prompt ---
if [[ "$OPT_JUST_DO_IT" == "true" ]]; then
    local_msg="This will sync ${SUMMARY_FILES_TRANSFERRED} file(s)"
    if [[ "$OPT_DELETE" == "true" && "$SUMMARY_FILES_DELETED" -gt 0 ]]; then
        local_msg="$local_msg and delete ${SUMMARY_FILES_DELETED} file(s)"
    fi
    local_msg="$local_msg. Continue?"

    if prompt_yn "$local_msg"; then
        execute_sync true
        exit $?
    else
        info "Aborted"
        exit 0
    fi
fi

# --- Confirm mode: prompt at each destructive step ---
if [[ "$OPT_CONFIRM" == "true" ]]; then
    # Step 1: Confirm sync
    if [[ "$SUMMARY_FILES_TRANSFERRED" -gt 0 ]]; then
        if prompt_yna "Sync ${SUMMARY_FILES_TRANSFERRED} file(s) from source to dest?"; then
            if [[ "$OPT_DELETE" == "true" && "$CONFIRM_ALL" != "true" ]]; then
                # Execute sync without delete first
                execute_sync false
                # Step 2: Confirm delete
                if [[ "$SUMMARY_FILES_DELETED" -gt 0 ]]; then
                    if prompt_yna "Delete ${SUMMARY_FILES_DELETED} file(s) from dest not in source?"; then
                        execute_delete
                    else
                        info "Skipped deletion"
                    fi
                else
                    info "No files to delete"
                fi
            else
                # No delete requested or CONFIRM_ALL set
                execute_sync true
            fi
        else
            info "Aborted"
            exit 0
        fi
    else
        info "Nothing to sync"
        if [[ "$OPT_DELETE" == "true" && "$SUMMARY_FILES_DELETED" -gt 0 ]]; then
            if prompt_yna "Delete ${SUMMARY_FILES_DELETED} file(s) from dest not in source?"; then
                execute_delete
            else
                info "Skipped deletion"
            fi
        else
            info "Already in sync"
        fi
    fi
    exit 0
fi

# --- Default mode: no prompts, just sync (no delete possible without flags) ---
execute_sync true

# .treeindexignore - patterns to exclude from treeindex generation
# Lines starting with # are comments
# Lines ending with / match directory names
# Other lines match file names (glob patterns)

# Build artifacts
_build/
deps/
node_modules/
cover/

# IDE and tool directories
.git/
.elixir_ls/
# Intent metadata (intent/.config/cache + backup excluded; config.json itself
# stays indexed -- it tells the LLM which Intent version + author this project
# is on).
intent/.config/cache/
intent/.config/backup/
.treeindex/

# Generated assets
priv/static/assets/

# System files
.DS_Store

# Compiled files
*.beam
*.ez
erl_crash.dump
